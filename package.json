{
  "name": "snacker",
  "version": "0.0.1",
  "private": true,
  "dependencies": {
    "body-parser": "~1.12.0",
    "bootstrap": "^3.3.4",
    "busboy": "^0.2.9",
    "cookie-parser": "~1.3.4",
    "csv-parser": "^1.5.2",
    "d3": "^3.5.5",
    "express": "^4.12.3",
    "griddle-react": "^0.2.12",
    "jquery": "^2.1.3",
    "react": "^0.13.1",
    "react-dropzone": "^1.0.1",
    "serve-favicon": "~2.2.0",
    "underscore": "^1.8.3"
  },
  "devDependencies": {
    "browserify": "^9.0.7",
    "catw": "^0.2.0",
    "chai": "^2.2.0",
    "convert-source-map": "^1.0.0",
    "imagemin": "^3.1.0",
    "mocha": "^2.2.1",
    "onchange": "^1.0.0",
    "reactify": "^1.1.0",
    "tap": "^0.7.1",
    "uglify-js": "^2.4.19",
    "watchify": "^3.1.0"
  },
  "scripts": {
    "build-js": "browserify --transform reactify browser/main.js | uglifyjs -mc > static/bundle.js",
    "build-css": "cat node_modules/bootstrap/dist/css/bootstrap.min.css browser/styles/*.css > static/bundle.css",
    "build": "npm run build-js && npm run build-css",
    "watch-js": "watchify browser/main.js -o static/bundle.js --debug --verbose",
    "watch-css": "catw static/styles/*.css -o static/bundle.css -v",
    "watch": "npm run watch-js & npm run watch-css & npm run post-js",
    "post-js": "onchange static/bundle.js -- npm test",
    "start": "npm run build && node server/main.js",
    "start-dev": "npm run watch & npm start",
    "test": "tap test/*.js"
  }
}

{
  "name": "snacker",
  "version": "0.0.1",
  "private": true,
  "dependencies": {
    "bootstrap": "^3.3.4",
    "busboy": "^0.2.9",
    "csv-parser": "^1.5.2",
    "express": "^4.12.3",
    "griddle-react": "^0.2.12",
    "jquery": "^2.1.3",
    "react": "^0.13.1",
    "react-dropzone": "^1.0.1",
    "taucharts": "^0.3.22",
    "underscore": "^1.8.3"
  },
  "devDependencies": {
    "browserify": "^9.0.7",
    "reactify": "^1.1.0",
    "tap": "^0.7.1",
    "uglify-js": "^2.4.19"
  },
  "scripts": {
    "build-min-js": "browserify --transform reactify browser/main.js | uglifyjs -mc > static/bundle.js",
    "build-js": "browserify --transform reactify browser/main.js > static/bundle.js",
    "build-css": "cat node_modules/bootstrap/dist/css/bootstrap.min.css browser/styles/*.css > static/bundle.css",
    "build": "npm run build-min-js && npm run build-css && npm run test",
    "build-dev": "npm run build-js && npm run build-css && npm run test",
    "start-dev": "npm run build-dev && node server/main.js",
    "start": "npm run build && node server/main.js",
    "test": "tap test/*.js"
  }
}

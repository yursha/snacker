{
  "name": "snacker",
  "version": "0.0.1",
  "private": true,
  "dependencies": {
    "body-parser": "~1.12.0",
    "bootstrap": "^3.3.4",
    "cookie-parser": "~1.3.4",
    "express": "^4.12.3",
    "jquery": "^2.1.3",
    "react": "^0.13.1",
    "react-dropzone": "^1.0.1",
    "serve-favicon": "~2.2.0"
  },
  "devDependencies": {
    "browserify": "^9.0.7",
    "catw": "^0.2.0",
    "chai": "^2.2.0",
    "convert-source-map": "^1.0.0",
    "imagemin": "^3.1.0",
    "mocha": "^2.2.1",
    "reactify": "^1.1.0",
    "tap": "^0.7.1",
    "uglify-js": "^2.4.19",
    "watchify": "^3.1.0"
  },
  "scripts": {
    "build-js": "browserify browser/main.js | uglifyjs -mc > static/bundle.js",
    "build-css": "cat static/styles/*.css > static/bundle.css",
    "build": "npm run build-js && npm run build-css",
    "watch-js": "watchify browser/main.js -o static/bundle.js --debug --verbose",
    "watch-css": "catw static/styles/*.css -o static/bundle.css -v",
    "watch": "npm run watch-js & npm run watch-css",
    "start": "npm run build && node server.js",
    "start-dev": "npm run watch & npm start",
    "test": "tap test/*.js"
  }
}
